{
  "expo": {
    "name": "seisamuse",
    "slug": "seisamuse",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.junxie.seisamuse",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.junxie.seisamuse"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "cd691f2c-c945-45f4-9bd3-f054e5dcc73c"
      }
    },
    "plugins": [
      "expo-sqlite"
    ]
  }
}
